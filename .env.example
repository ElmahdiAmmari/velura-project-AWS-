# ============================================================
# Velura — Environment Variables
# Copy this file to .env and fill in real values.
# Docker Compose: cd infra/docker && docker compose --env-file ../../.env up
# NEVER commit .env to git.
# For AWS: store secrets in AWS Secrets Manager and reference
# them via ECS task definition secrets or Parameter Store.
# ============================================================

# ---- MySQL root (used by the mysql container itself) -------
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# ---- MySQL app user (used by all Flask services) -----------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rental_user
MYSQL_PASSWORD=change_me_strong_app_password
MYSQL_DATABASE=clothes_rental

# ---- Auth service ------------------------------------------
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
AUTH_SERVICE_PORT=5001

# ---- Other service ports -----------------------------------
CATALOG_SERVICE_PORT=5002
RENTAL_SERVICE_PORT=5003
ADMIN_SERVICE_PORT=5004

# ---- Internal service-to-service URL -----------------------
# Local Docker: http://auth-service:5001
# AWS ECS (Service Discovery): http://auth.velura.local:5001
# AWS ECS (ALB internal): http://internal-alb-dns:5001
AUTH_SERVICE_URL=http://auth-service:5001

# ---- Frontend (build args for frontend/Dockerfile) ---------
# UI: http://localhost:8080 — sources in frontend/index.html
# Local: browser calls APIs on localhost ports below
# AWS: ALB / CloudFront URLs per service
FRONTEND_AUTH_URL=http://localhost:5001
FRONTEND_CATALOG_URL=http://localhost:5002
FRONTEND_RENTAL_URL=http://localhost:5003
FRONTEND_ADMIN_URL=http://localhost:5004

# ---- Flask -------------------------------------------------
# Set to false in production
FLASK_DEBUG=false

# ---- Elasticsearch -----------------------------------------
ELASTIC_PASSWORD=change_me_strong_elastic_password
ELASTICSEARCH_HOSTS=http://clothes_elasticsearch:9200

# ---- Kibana ------------------------------------------------
KIBANA_PASSWORD=change_me_strong_kibana_password
# Must be exactly 32 characters — generate with: openssl rand -hex 16
KIBANA_ENCRYPTION_KEY=change_me_exactly_32_chars_key!!

# ---- Filebeat ----------------------------------------------
KIBANA_HOST=kibana:5601
